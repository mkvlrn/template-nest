{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "source debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import=tsx", "--import=./src/env.ts"],
      "program": "${workspaceFolder}/src/main.ts",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    }
  ]
}
