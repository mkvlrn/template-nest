{
  "name": "template-nest",
  "description": "A revamped/modernized template for NestJS projects using esm",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-nest"
  },
  "keywords": [
    "nestjs",
    "esm",
    "template"
  ],
  "engines": {
    "node": "24",
    "pnpm": "11"
  },
  "imports": {
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "dev": "node --watch ./src/main.ts",
    "start": "node ./src/main.ts",
    "lint": "pnpm lint-check --write",
    "lint-check": "biome check --diagnostic-level=warn --no-errors-on-unmatched",
    "typecheck": "tsc",
    "typecheck-staged": "tsc-files",
    "test": "vitest",
    "test-staged": "vitest related --bail=1 --reporter=github-actions",
    "test-ci": "vitest --bail=1 --reporter=github-actions",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@mkvlrn/config": "^4.0.2",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "lefthook": "^2.1.8",
    "supertest": "^7.2.2",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@mkvlrn/app-error": "^0.0.5",
    "@mkvlrn/result": "^5.0.8",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "envalid": "^8.1.1",
    "http-status-codes": "^2.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.3"
  }
}
