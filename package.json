{
  "name": "template-nest",
  "description": "A template for NestJS projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-nest"
  },
  "keywords": [
    "nest",
    "template"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:cov": "rimraf coverage && vitest run --coverage",
    "prepare": "husky",
    "dev": "node --import @swc-node/register/esm-register --watch src/index.ts",
    "lint": "eslint src --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "build": "rimraf dist && nest build && rimraf -g dist/**/*.spec.js",
    "start": "node dist"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@mkvlrn/eslint-config": "^24.6.5",
    "@mkvlrn/prettier-config": "^24.6.1",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.9",
    "@swc-node/register": "^1.9.1",
    "@swc/cli": "^0.3.12",
    "@swc/core": "1.5.24",
    "@swc/plugin-transform-imports": "^2.0.4",
    "@swc/types": "^0.1.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.1",
    "@types/superagent": "^8.1.7",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.12.0",
    "unplugin-swc": "^1.4.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.9",
    "@nestjs/core": "^10.3.9",
    "@nestjs/platform-express": "^10.3.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
